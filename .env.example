# Example environment configuration  
# Copy this file to .env and fill in your values
#
# ══════════════════════════════════════════════════════════════
#  LOCAL DEVELOPMENT   →  Use FAISS + sentence-transformers
#  CLOUD / PRODUCTION  →  Use Qdrant Cloud + Gemini embeddings
# ══════════════════════════════════════════════════════════════

# ── Document processing ────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# ── LLM (required) ────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Alternatively, use OpenAI:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo

# ── Embeddings ─────────────────────────────────────────────────
# LOCAL: sentence-transformers (no API key needed, ~90 MB model download)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# CLOUD / PRODUCTION: switch to Gemini embeddings (no local model needed)
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=models/text-embedding-004
# EMBEDDING_DIMENSION=768

# ── Vector store ───────────────────────────────────────────────
# LOCAL: FAISS (stores index on disk)
VECTOR_STORE_BACKEND=faiss
VECTOR_STORE_PATH=data/vector_store
METADATA_PATH=data/metadata.json

# CLOUD / PRODUCTION: Qdrant Cloud (stateless, free tier available at cloud.qdrant.io)
# VECTOR_STORE_BACKEND=qdrant
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key_here
# QDRANT_COLLECTION_NAME=documents

# ── Streamlit UI → backend URL ─────────────────────────────────
# LOCAL: leave unset (defaults to http://localhost:8000)
# CLOUD: set to your Cloud Run service URL
# API_BASE_URL=https://docqa-backend-xxxx-uc.a.run.app

# ── API server ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── File upload ────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50